{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "APP_URL",
    "AWS_ACCESS_KEY_ID",
    "AWS_BUCKET_NAME",
    "AWS_REGION",
    "AWS_SECRET_ACCESS_KEY",
    "BASE_URL",
    "CI",
    "CLERK_PUBLISHABLE_KEY",
    "CLERK_SECRET_KEY",
    "CLERK_WEBHOOK_SECRET",
    "E2E_PORT",
    "E2E_PROFILE_SCENARIO",
    "E2E_TEST_DB_URL",
    "LOCAL_DATABASE_URL",
    "LOCAL_QUERY_PROFILER",
    "LOCAL_QUERY_PROFILER_OUTPUT",
    "LOCAL_QUERY_PROFILER_RESET",
    "NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY",
    "NEXT_PUBLIC_CLOUDFLARE_URL",
    "NEXT_PUBLIC_POSTHOG_HOST",
    "NEXT_PUBLIC_POSTHOG_KEY",
    "NEXT_PUBLIC_SENTRY_ENABLED",
    "NODE_ENV",
    "PLAYWRIGHT_LOCAL_E2E",
    "PORT",
    "SKIP_ENV_VALIDATION",
    "STRIPE_PRICE_ID",
    "STRIPE_SECRET_KEY",
    "STRIPE_WEBHOOK_SECRET",
    "TURSO_API_TOKEN",
    "TURSO_DATABASE_AUTH_TOKEN",
    "TURSO_DATABASE_URL",
    "TURSO_SNAPSHOT_DB_NAME",
    "TURSO_SNAPSHOT_OUTPUT_DB_PATH",
    "USE_TURSO_DB",
    "USE_TURSO_DB_FOR_BUILD",
    "VERCEL",
    "VERCEL_AUTOMATION_BYPASS_SECRET"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "lint": {
      "dependsOn": ["^lint"]
    },
    "start": {
      "cache": false,
      "persistent": true
    },
    "test": {
      "dependsOn": ["^test"]
    },
    "test:e2e": {
      "cache": false
    },
    "test:e2e:attach": {
      "cache": false
    },
    "test:watch": {
      "cache": false,
      "persistent": true
    },
    "typecheck": {
      "dependsOn": ["^typecheck"]
    }
  }
}
