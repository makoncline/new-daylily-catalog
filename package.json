{
  "name": "daylily-catalog",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "main": "pnpm --filter @daylily-catalog/main",
    "dev": "TURBO_CACHE_DIR=.turbo turbo run dev --filter=@daylily-catalog/main",
    "build": "TURBO_CACHE_DIR=.turbo turbo run build --filter=@daylily-catalog/main",
    "build:next": "TURBO_CACHE_DIR=.turbo turbo run build:next --filter=@daylily-catalog/main",
    "lint": "TURBO_CACHE_DIR=.turbo turbo run lint --filter=@daylily-catalog/main",
    "typecheck": "TURBO_CACHE_DIR=.turbo turbo run typecheck --filter=@daylily-catalog/main",
    "test": "TURBO_CACHE_DIR=.turbo turbo run test --filter=@daylily-catalog/main",
    "test:watch": "TURBO_CACHE_DIR=.turbo turbo run test:watch --filter=@daylily-catalog/main",
    "test:e2e": "TURBO_CACHE_DIR=.turbo turbo run test:e2e --filter=@daylily-catalog/main",
    "test:e2e:attach": "TURBO_CACHE_DIR=.turbo turbo run test:e2e:attach --filter=@daylily-catalog/main",
    "start": "TURBO_CACHE_DIR=.turbo turbo run start --filter=@daylily-catalog/main",
    "start:standalone": "TURBO_CACHE_DIR=.turbo turbo run start:standalone --filter=@daylily-catalog/main",
    "start-tunnel": "TURBO_CACHE_DIR=.turbo turbo run start-tunnel --filter=@daylily-catalog/main",
    "env:dev": "pnpm --filter @daylily-catalog/main env:dev",
    "env:prod": "pnpm --filter @daylily-catalog/main env:prod",
    "db:push": "TURBO_CACHE_DIR=.turbo turbo run db:push --filter=@daylily-catalog/main",
    "db:generate": "TURBO_CACHE_DIR=.turbo turbo run db:generate --filter=@daylily-catalog/main",
    "db:studio": "TURBO_CACHE_DIR=.turbo turbo run db:studio --filter=@daylily-catalog/main",
    "db:seed:local-dev": "TURBO_CACHE_DIR=.turbo turbo run db:seed:local-dev --filter=@daylily-catalog/main",
    "migrate:generate": "TURBO_CACHE_DIR=.turbo turbo run migrate:generate --filter=@daylily-catalog/main",
    "browser-tools-server": "TURBO_CACHE_DIR=.turbo turbo run browser-tools-server --filter=@daylily-catalog/main",
    "profile:queries": "TURBO_CACHE_DIR=.turbo turbo run profile:queries --filter=@daylily-catalog/main",
    "db:sync:seed": "TURBO_CACHE_DIR=.turbo turbo run db:sync:seed --filter=@daylily-catalog/main"
  },
  "devDependencies": {
    "turbo": "^2.9.6"
  },
  "pnpm": {
    "overrides": {
      "@tanstack/query-core": "5.86.0",
      "@types/react": "19.2.14",
      "@types/react-dom": "19.2.3"
    }
  }
}
