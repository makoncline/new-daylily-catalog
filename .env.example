# Copy this file to `.env` and fill in real values before deploy.
# See `docs/deploy-vps.md` for Docker and VPS details.

# Compose image selection
IMAGE_TAG="main-<shortsha>"

# Non-secrets
APP_BASE_URL="https://vps-test.daylilycatalog.com"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
NEXT_PUBLIC_CLOUDFLARE_URL=""
NEXT_PUBLIC_SENTRY_ENABLED="false"
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""
STRIPE_PRICE_ID=""

# Database mode
# Recommended on the VPS: leave USE_TURSO_DB="true" and provide Turso creds.
# If you set USE_TURSO_DB="false", also set LOCAL_DATABASE_URL and add a persistent /data volume.
USE_TURSO_DB="true"
TURSO_DATABASE_URL=""
LOCAL_DATABASE_URL="file:/data/daylilycatalog.sqlite"

# Secrets
TURSO_DATABASE_AUTH_TOKEN=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Build-only
# Docker builds need:
# APP_BASE_URL
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# NEXT_PUBLIC_CLOUDFLARE_URL
# NEXT_PUBLIC_SENTRY_ENABLED="false"
# TURSO_DATABASE_URL
# TURSO_DATABASE_AUTH_TOKEN
# Optional: STRIPE_SECRET_KEY for cold-cache-safe Stripe-derived metadata.
# Optional build flags:
# USE_TURSO_DB_FOR_BUILD="true"
# TURSO_SNAPSHOT_DB_NAME=""
# TURSO_API_TOKEN=""
# SENTRY_AUTH_TOKEN=""
