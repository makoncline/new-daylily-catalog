# Runtime environment for Docker Compose on the VPS.
# Copy this file to ".env" and fill in real values before deploy.

# Non-secrets
APP_BASE_URL="https://daylilycatalog.makon.dev"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
NEXT_PUBLIC_CLOUDFLARE_URL=""
NEXT_PUBLIC_SENTRY_ENABLED="false"
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""
STRIPE_PRICE_ID=""

# Database mode
# Recommended on the VPS: leave USE_TURSO_DB="true" and provide Turso creds.
# If you switch to USE_TURSO_DB="false", also set LOCAL_DATABASE_URL and add a persistent /data volume.
USE_TURSO_DB="true"
TURSO_DATABASE_URL=""
LOCAL_DATABASE_URL="file:/data/daylilycatalog.sqlite"

# Secrets
TURSO_DATABASE_AUTH_TOKEN=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Build-time only
# The Docker image build prerenders public routes and sitemap data, so it needs the same app env file.
# For non-Vercel builds, set APP_BASE_URL so canonical URLs, metadata, robots, and sitemap do not fall back to localhost.
# Pass that file to `docker build` with:
# docker build --secret id=app_env,src=.env -t ghcr.io/makoncline/daylilycatalog:latest .
#
# Minimum verified Docker build env for this repo:
# APP_BASE_URL
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# NEXT_PUBLIC_CLOUDFLARE_URL
# NEXT_PUBLIC_SENTRY_ENABLED="false"
# TURSO_DATABASE_URL
# TURSO_DATABASE_AUTH_TOKEN
#
# Stripe nuance:
# STRIPE_SECRET_KEY was not required for the verified build when using the current production DB state,
# because subscription cache data already existed in the DB. Keep it available if you need cold-cache-safe
# correctness for public route generation.
#
# Additional optional build flags:
# USE_TURSO_DB_FOR_BUILD="true"
# TURSO_SNAPSHOT_DB_NAME=""
# TURSO_API_TOKEN=""
# SENTRY_AUTH_TOKEN=""
