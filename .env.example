# Copy this file to `.env` and fill in real values before deploy.
# See `docs/deploy-vps.md` for Docker and VPS details.

# Compose image selection
IMAGE_TAG="main-<shortsha>"

# Non-secrets
# Canonical public origin for metadata, robots, sitemap, feeds, and email links.
# Set this to the apex even while `prod.daylilycatalog.com` remains live for rollout/testing.
APP_BASE_URL="https://daylilycatalog.com"
VERCEL_AUTOMATION_BYPASS_SECRET=""
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
NEXT_PUBLIC_CLOUDFLARE_URL=""
NEXT_PUBLIC_SENTRY_ENABLED="false"
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
NEXT_PUBLIC_USE_V2_CULTIVAR_DISPLAY_DATA="false"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""
V2_IMAGE_REVIEW_S3_BUCKET=""
V2_IMAGE_REVIEW_S3_PREFIX="v2-ahs-image-review"
STRIPE_PRICE_ID=""

# Database
# Turso/libSQL runtime: DATABASE_URL="libsql://..."
# Local SQLite runtime: DATABASE_URL="file:/data/daylilycatalog.sqlite"
DATABASE_URL=""
# Optional read replica for cultivar/AHS lookup and dashboard cultivar hydration.
# Embedded replica example:
# CULTIVAR_READ_DATABASE_URL="file:/data/daylily-cultivar-read-replica.sqlite"
# CULTIVAR_READ_SYNC_URL="libsql://..."
# CULTIVAR_READ_SYNC_INTERVAL_SECONDS="3600"
CULTIVAR_READ_DATABASE_URL=""
CULTIVAR_READ_SYNC_URL=""
CULTIVAR_READ_SYNC_INTERVAL_SECONDS=""

# Secrets
TURSO_DATABASE_AUTH_TOKEN=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Build-only
# Docker builds need:
# APP_BASE_URL (canonical apex public origin)
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY
# NEXT_PUBLIC_CLOUDFLARE_URL
# NEXT_PUBLIC_SENTRY_ENABLED="false"
# NEXT_PUBLIC_USE_V2_CULTIVAR_DISPLAY_DATA="false"
# DATABASE_URL
# TURSO_DATABASE_AUTH_TOKEN (required only when DATABASE_URL uses libsql://)
# Optional: STRIPE_SECRET_KEY for cold-cache-safe Stripe-derived metadata.
# SENTRY_AUTH_TOKEN=""
