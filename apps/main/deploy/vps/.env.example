# Copy this file to `.env` on the server stack directory and fill in real values.
# The server runtime source of truth is `/srv/stacks/daylilycatalog/.env`.

# Compose image selection
IMAGE_TAG="main-<shortsha>"

# Non-secrets
# Canonical public origin for metadata, robots, sitemap, feeds, and email links.
# Set this to the apex even while `prod.daylilycatalog.com` remains live for rollout/testing.
APP_BASE_URL="https://daylilycatalog.com"
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
NEXT_PUBLIC_CLOUDFLARE_URL=""
NEXT_PUBLIC_SENTRY_ENABLED="true"
NEXT_PUBLIC_POSTHOG_KEY="phc_live_key"
NEXT_PUBLIC_POSTHOG_HOST="https://us.i.posthog.com"
AWS_REGION="us-east-1"
AWS_BUCKET_NAME=""
USE_IMAGE_ASSETS="false"
R2_BUCKET_NAME="daylily-catalog-media"
R2_PUBLIC_BASE_URL="https://media.daylilycatalog.com"
STRIPE_PRICE_ID=""

# Database
# Turso/libSQL runtime: DATABASE_URL="libsql://..."
# Local SQLite runtime: DATABASE_URL="file:/data/daylilycatalog.sqlite"
DATABASE_URL=""
# Optional VPS-only Turso embedded replica. Keep DATABASE_URL as the remote libsql:// URL.
# Public page reads use this local file; dashboard reads and all writes still use DATABASE_URL.
TURSO_EMBEDDED_REPLICA_URL="file:/data/turso-replica.db"
TURSO_EMBEDDED_REPLICA_SYNC_INTERVAL_SECONDS="600"
# Public search source replica syncs before index rebuilds. Set to 0 to disable rebuilds.
PUBLIC_SEARCH_INDEX_REFRESH_INTERVAL_SECONDS="3600"

# Secrets
TURSO_DATABASE_AUTH_TOKEN=""
CLERK_SECRET_KEY=""
CLERK_WEBHOOK_SECRET=""
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
