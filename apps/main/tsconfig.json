{
  "extends": "../../packages/config/tsconfig/base.json",
  "compilerOptions": {
    /* Bundled projects */
    "lib": ["dom", "dom.iterable", "ES2022"],
    "noEmit": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "plugins": [{ "name": "next" }],
    "types": ["vitest/globals"],
    "incremental": true,

    /* Path Aliases */
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"],
      "@/env": ["./src/env.js"]
    }
  },
  "include": [
    ".eslintrc.cjs",
    "next-env.d.ts",
    "**/*.ts",
    "**/*.tsx",
    "**/*.cjs",
    "**/*.js",
    "src/app/.well-known/**/*.ts",
    ".next/types/**/*.ts",
    ".next/dev/types/**/*.ts",
    "src/env.js"
  ],
  "exclude": [
    "node_modules",
    "downloads",
    "local",
    "playwright-report",
    "src/components/ui/**/*"
  ]
}
